# BitBrowser Local API URL shown in BitBrowser system settings.
BIT_BROWSER_API_URL=http://127.0.0.1:54346

# Keep this profile separate from tavily-register.
# Leave the ID empty to find or create the exact profile name below.
BIT_BROWSER_ID=
BIT_BROWSER_NAME=outlook-register

# The profile is retained and reused after each task.
BIT_BROWSER_CLOSE_WAIT=5
BROWSER_TIMEOUT=30000
HEADLESS=false
