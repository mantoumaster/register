# Copy this file to .env and replace the placeholder values.

# BitBrowser Local API URL shown in BitBrowser system settings.
# The port can vary by installation; do not assume it is always 54346.
BIT_BROWSER_API_URL=http://127.0.0.1:54346

# Optional existing browser profile ID. Leave empty to reuse by exact name.
BIT_BROWSER_ID=
BIT_BROWSER_NAME=tavily-register

# Keep one reusable profile and wait for the process to exit before cleanup.
BIT_BROWSER_CLOSE_WAIT=5

# Email provider: luckmail or outlook_tw.
EMAIL_PROVIDER=luckmail

# LuckMail server and API credentials. The URL below is the built-in default.
LUCKMAIL_BASE_URL=https://mails.luckyous.com
LUCKMAIL_API_KEY=replace-with-your-api-key

# Optional HMAC authentication.
LUCKMAIL_API_SECRET=
LUCKMAIL_USE_HMAC=false

# LuckMail does not provide a Tavily project type, so reuse the Grok type.
LUCKMAIL_PROJECT_CODE=grok

# Optional LuckMail allocation filters.
LUCKMAIL_EMAIL_TYPE=ms_graph
LUCKMAIL_DOMAIN=outlook.com
LUCKMAIL_POLL_INTERVAL=3
MAX_EMAIL_WAIT_TIME=300

# outlook.tw does not require credentials.
OUTLOOK_TW_BASE_URL=https://outlook.tw
OUTLOOK_TW_USERNAME_LENGTH=8
OUTLOOK_TW_DOMAIN_INDEX=0
OUTLOOK_TW_POLL_INTERVAL=3
OUTLOOK_TW_REQUEST_TIMEOUT=30
OUTLOOK_TW_REQUEST_RETRIES=3

# Tavily browser defaults.
HEADLESS=false
BROWSER_TIMEOUT=30000

# Random pause before each browser interaction. Set both to 0 to disable.
HUMAN_DELAY_MIN=0.8
HUMAN_DELAY_MAX=2.4
